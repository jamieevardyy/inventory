# ─── MongoDB ──────────────────────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB="ai_inventory"

# ─── BunnyCDN Storage ─────────────────────────────────────────────────────
# Storage Zone name (e.g. "my-inventory")
BUNNY_STORAGE_ZONE="your-storage-zone"
# Storage Zone password / access key (Storage → FTP & API Access → Password)
BUNNY_STORAGE_API_KEY="your-storage-password"
# Storage region host. FalCloud default is "storage.bunnycdn.com".
# Regions: storage.bunnycdn.com (DE/Falkenstein), ny.storage.bunnycdn.com (NY),
# la.storage.bunnycdn.com (LA), sg.storage.bunnycdn.com (SG), syd / uk / etc.
BUNNY_STORAGE_HOST="storage.bunnycdn.com"
# Public Pull Zone URL that serves the storage zone (no trailing slash)
# e.g. https://my-inventory.b-cdn.net
BUNNY_PULL_ZONE_URL="https://your-zone.b-cdn.net"

# ─── Ollama Vision (optional — falls back to a built-in mock if unreachable) ─
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_VISION_MODEL="qwen2.5vl:7b"
# Set to "true" to force the mock and never call Ollama
AI_MOCK="false"

# ─── App ───────────────────────────────────────────────────────────────────
# Used as Created By / Modified By when no auth layer is present
DEFAULT_USER="system"
